<UserControl x:Class="AdivinaQuienServidor.Views.ResultadoView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:AdivinaQuienServidor.Views"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <UserControl.Background>
        <ImageBrush ImageSource="https://wallpapers.com/images/hd/colorful-pokemon-anime-hd-12w1bgtvd51z5zrt.jpg" 
                  Stretch="UniformToFill" 
                  Opacity="0.2"/>
    </UserControl.Background>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#EE1515" Height="80" VerticalAlignment="Top">
            <StackPanel VerticalAlignment="Center">
                <Label Content="¡TENEMOS UN GANADOR!" 
                     HorizontalAlignment="Center" 
                     FontFamily="Bernard MT Condensed" 
                     FontSize="32" 
                     Foreground="White" 
                     FontWeight="Bold">
                    <Label.Effect>
                        <DropShadowEffect Color="#3B4CCA" BlurRadius="4" ShadowDepth="4" Direction="320"/>
                    </Label.Effect>
                </Label>
            </StackPanel>
        </Border>

        <StackPanel Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center">

            <Border Background="White" 
                  Width="200" 
                  Height="200" 
                  CornerRadius="100" 
                  BorderBrush="#FFDE00" 
                  BorderThickness="5"
                  Padding="10">
                <Border.Effect>
                    <DropShadowEffect Color="#FFDE00" BlurRadius="20" ShadowDepth="0"/>
                </Border.Effect>
                <Grid>
                    <Image Source="/Resources/Images/Alakazam.png" Stretch="Uniform" Margin="10"/>
                </Grid>
            </Border>

            <Label Content="¡Felicidades!" 
                 HorizontalAlignment="Center" 
                 FontSize="20" 
                 Foreground="#3B4CCA" 
                 FontWeight="Bold" 
                 Margin="0,15,0,0"/>

            <TextBlock Text="El Pokemon era:" 
                     HorizontalAlignment="Center" 
                     FontSize="28" 
                     FontFamily="Bernard MT Condensed" 
                     Foreground="#EE1515" 
                     FontWeight="Bold">
                <TextBlock.Effect>
                    <DropShadowEffect Color="Gray" BlurRadius="2" ShadowDepth="2" Opacity="0.5"/>
                </TextBlock.Effect>
            </TextBlock>
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,20">
            <Button Content="Jugar de Nuevo" 
                  Height="40" 
                  Width="160" 
                  Background="#3B4CCA" 
                  Foreground="White" 
                  FontWeight="Bold" 
                  FontSize="16" 
                  Margin="10">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="10"/>
                    </Style>
                </Button.Resources>
            </Button>

            <Button Content="Salir" 
                  Height="40" 
                  Width="100" 
                  Background="#555" 
                  Foreground="White" 
                  FontWeight="Bold" 
                  FontSize="16" 
                  Margin="10">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="10"/>
                    </Style>
                </Button.Resources>
            </Button>
        </StackPanel>
    </Grid>
</UserControl>
